{
    "name": "eslint-plugin-slop-refinery",
    "version": "0.0.0",
    "description": "Refines AI slop into clean code: correct, simple, maintainable",
    "type": "module",
    "license": "MIT",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./dist/src/index.js"
        }
    },
    "files": [
        "dist/src",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "prettier --write . && eslint --fix --config eslint.format.config.ts .",
        "lint": "eslint .",
        "ruleset:pull": "tsx ./scripts/pull-ruleset.ts",
        "ruleset:push": "tsx ./scripts/push-ruleset.ts",
        "typecheck": "tsc --noEmit",
        "prepack": "tsx ./scripts/prepack.ts",
        "test": "vitest run"
    },
    "peerDependencies": {
        "eslint": "^9.0.0"
    },
    "dependencies": {
        "@eslint/js": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-check-file": "^3.3.1",
        "eslint-plugin-functional": "^9.0.2",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-perfectionist": "^5.8.0",
        "eslint-plugin-sonarjs": "^4.0.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.52.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "eslint": "^9.39.2",
        "jiti": "^2.6.1",
        "prettier": "^3.7.4",
        "tsx": "^4.21.0",
        "vitest": "^4.0.16"
    }
}
