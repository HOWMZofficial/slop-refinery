{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "esModuleInterop": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "rewriteRelativeImportExtensions": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ESNext",
        "types": ["node"]
    },
    "exclude": ["skills/slop-refinery-setup/references/templates"],
    "include": [
        "eslint",
        "eslint.config.ts",
        "eslint.format.config.ts",
        "scripts",
        "skills",
        "src",
        "tests"
    ]
}
